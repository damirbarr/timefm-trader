# Trading mode
PAPER_MODE=true                  # set to false for real money
INITIAL_BALANCE=10000            # starting fake balance in USD

# Binance (only needed for PAPER_MODE=false)
BINANCE_API_KEY=
BINANCE_SECRET=
BNB_DISCOUNT=false               # set true if you hold BNB for fee discount

# Risk management
STOP_LOSS_PCT=-0.04              # -4% hard stop loss
MIN_CONFIDENCE=0.3               # minimum signal confidence to trade
RESERVE_PCT=0.10                 # % of portfolio always kept as free USDT
MAX_POSITION_PCT=0.30            # max % of portfolio in a single coin
MIN_TRADE_USD=10                 # ignore signals below this size

# Bot loop
SCAN_INTERVAL_S=60               # full market scan every N seconds
STOP_LOSS_CHECK_S=30             # stop-loss check interval

# Web dashboard
WEB_PORT=8080
CONTROL_API_TOKEN=change-me      # token for /control/* endpoints
